{
  "_comment": "複製此檔案為 appsettings.Secrets.json 並填入實際值。此檔案不應提交到版本控制。",
  "_security_note": "重要：請勿使用 SA 帳號！請使用 Scripts/CreateAppDatabaseUser.sql 建立專用帳號。",

  "TeraLinkaAuth": {
    "ConnectionString": "Server=YOUR_SERVER;Database=TeraLinkaServer;User Id=isoftviewer_app;Password=YOUR_STRONG_PASSWORD;TrustServerCertificate=True;",
    "Jwt": {
      "SecretKey": "YOUR_JWT_SECRET_KEY_AT_LEAST_64_BYTES_BASE64_ENCODED"
    }
  },

  "Database": {
    "ServerName": "YOUR_SERVER",
    "DatabaseName": "TeraLinkaServer",
    "DBUserID": "isoftviewer_app",
    "DBPassword": "YOUR_STRONG_PASSWORD"
  }
}
